# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# Microsoft Graph (app-only / client credentials flow)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_USER_ID=andrew@crymbleandsons.com

# BeepMate (WhatsApp send-only gateway — https://beepmate.io)
# TARGET_ID is either your phone number in international format (e.g. 447545972340)
# or a BeepMate Group ID, found in the BeepMate dashboard.
BEEPMATE_API_KEY=
BEEPMATE_TARGET_ID=

# Webhook auth shared secret — must be at least 16 characters.
# Every /ingest/* request must include header X-Brain-Token: <this value>.
INGEST_TOKEN=

# App
PORT=3000
TZ=Europe/London
LOG_LEVEL=info
NODE_ENV=production

# Optional: override SQLite path (default ./brain.db)
# DB_PATH=/data/brain.db
